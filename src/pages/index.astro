---
import App from '../components/App';
import { GOOGLE_ANALYTICS_CONFIG } from '../config/googleAnalytics';
import '../styles/global.css';
---

<!DOCTYPE html>
<html lang="bn">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="generator" content={Astro.generator} />

    <!-- SEO Meta Tags -->
    <title>Building Management System - Service Charges & Residents</title>
    <meta
      name="description"
      content="Complete building management solution for apartment complexes. Manage residents, flats, service charge bills with ease. Free tool with print preview and data export. Available in English and Bangla."
    />
    <meta
      name="keywords"
      content="building management, apartment management, resident management, flat management, service charge calculator, building bill calculator, Bangladesh building management, বিল্ডিং ম্যানেজমেন্ট, সার্ভিস চার্জ ক্যালকুলেটর"
    />
    <meta name="author" content="Ankur Mursalin" />

    <!-- Open Graph / Facebook -->
    <meta property="og:type" content="website" />
    <meta property="og:url" content="https://encryptioner.github.io/service-charge/" />
    <meta property="og:title" content="Building Management System - Service Charges & Residents" />
    <meta
      property="og:description"
      content="Complete building management solution for apartment complexes. Manage residents, flats, and service charge bills with ease."
    />

    <!-- Twitter -->
    <meta property="twitter:card" content="summary_large_image" />
    <meta property="twitter:url" content="https://encryptioner.github.io/service-charge/" />
    <meta property="twitter:title" content="Building Management System" />
    <meta
      property="twitter:description"
      content="Complete building management solution for apartment complexes. Manage residents, flats, and service charges."
    />

    <!-- Favicon -->
    <link rel="icon" type="image/svg+xml" href={`${import.meta.env.BASE_URL}favicon.svg`} />

    <!-- PWA Manifest -->
    <link rel="manifest" href={`${import.meta.env.BASE_URL}manifest.json`} />
    <meta name="mobile-web-app-capable" content="yes" />
    <meta name="apple-mobile-web-app-capable" content="yes" />
    <meta name="apple-mobile-web-app-status-bar-style" content="default" />
    <meta name="apple-mobile-web-app-title" content="Building Management" />

    <!-- Theme Color -->
    <meta name="theme-color" content="#2563eb" />
  </head>
  <body>
    <App client:load />

    {GOOGLE_ANALYTICS_CONFIG.shouldTrack && (
      <>
        <script is:inline async src={`https://www.googletagmanager.com/gtag/js?id=${GOOGLE_ANALYTICS_CONFIG.measurementId}`}></script>
        <script is:inline define:vars={{ measurementId: GOOGLE_ANALYTICS_CONFIG.measurementId }}>
          window.dataLayer = window.dataLayer || [];
          function gtag(){dataLayer.push(arguments);}
          gtag('js', new Date());
          gtag('config', measurementId);
          console.log('[Google Analytics] Initialized successfully with ID:', measurementId);
        </script>
      </>
    )}

    <script>
      // Register Service Worker for PWA offline support
      if ('serviceWorker' in navigator) {
        window.addEventListener('load', () => {
          const swPath = `${import.meta.env.BASE_URL}sw.js`;
          navigator.serviceWorker
            .register(swPath)
            .then((registration) => {
              console.log('Service Worker registered:', registration.scope);
            })
            .catch((error) => {
              console.log('Service Worker registration failed:', error);
            });
        });
      }
    </script>
  </body>
</html>
